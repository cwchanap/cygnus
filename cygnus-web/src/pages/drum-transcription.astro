---
import MainLayout from '@/layouts/main.astro';
import DrumFileUpload from '../components/DrumFileUpload.svelte';
---

<MainLayout content={{ title: 'Drum Transcription — Cygnus' }}>
  <div class="container mx-auto px-6 py-10 max-w-3xl">

    <!-- Hero -->
    <div class="mb-8 animate-slide-up">
      <div class="inline-flex items-center gap-2.5 bg-[#c2ff00]/[0.08] border border-[#c2ff00]/20 rounded-full px-4 py-1.5 mb-5">
        <div class="w-1.5 h-1.5 rounded-full bg-[#c2ff00] pulse-dot"></div>
        <span class="text-[#c2ff00] font-mono text-[10px] uppercase tracking-[0.2em]">AI Transcription Engine</span>
      </div>
      <h1 class="font-display font-black text-white text-4xl md:text-5xl leading-none mb-3 tracking-tight">
        DRUM<br/>
        <span class="text-[#c2ff00]">TRANSCRIBE</span>
      </h1>
      <p class="text-[#6060a0] font-mono text-sm leading-relaxed max-w-md">
        Upload drum audio. Get precise MIDI transcription — powered by TensorFlow and Magenta AI.
      </p>
    </div>

    <!-- Main card -->
    <div class="bg-[#0d0c1e] border border-white/[0.06] rounded-xl overflow-hidden animate-slide-up-delay-1">

      <!-- Upload section -->
      <div class="p-7">
        <h2 class="font-display font-black text-white text-sm uppercase tracking-widest mb-5">Upload Audio</h2>
        <DrumFileUpload client:load />
      </div>

    </div>
  </div>
</MainLayout>
